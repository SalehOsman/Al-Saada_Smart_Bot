# Bot Configuration
# Get your bot token from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Super Admin Initialization
# Provide your Telegram ID to bypass the join flow as the Super Admin
INITIAL_SUPER_ADMIN_ID=

# Webhook Configuration
# Optional: Set this for webhook mode, leave empty for polling
# WEBHOOK_URL=

# Database Configuration
# PostgreSQL connection string
DATABASE_URL=postgresql://al_saada_user:secure_password_here@localhost:5434/al_saada_bot

# Redis Configuration
# Redis connection string (optional, defaults to redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# Server Configuration
# Port for the HTTP server (optional, defaults to 3000)
PORT=3000

# Environment
# One of: development, production, test (optional, defaults to development)
NODE_ENV=development

# Logging Configuration
# One of: debug, info, warn, error (optional, defaults to info)
LOG_LEVEL=info

# Sentry Integration (Optional - feature is opt-in)
# SENTRY_DSN=https://your-sentry-dsn-or-self-hosted-url

# Backup Configuration
BACKUP_ENABLED=false
BACKUP_SCHEDULE="0 2 * * *"  # Cron: Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=./backups
BACKUP_ENCRYPTION_KEY=your-encryption-key-here

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=30
RATE_LIMIT_WINDOW_MINUTES=1

# PostgreSQL Configuration (for Docker Compose)
POSTGRES_USER=al_saada_user
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=al_saada_bot